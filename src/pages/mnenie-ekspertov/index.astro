---
import BaseLayout from "@src/layouts/DefaultLayout.astro"
import Markdown from "@components/Markdown/Markdown.astro"
import Card from "@components/Card/Card.astro"

const mdFiles = import.meta.glob("./md/*.md", { query: "?raw", import: "default", eager: true })
const cards = Object.values(mdFiles)
---

<BaseLayout title="Мнение экспертов" description="Что говорят опрошенные экперты.">
	{cards.map((content) => (
		<Card>
			<Markdown content={content} />
		</Card>
	))}
</BaseLayout>
